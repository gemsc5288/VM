@Anotation {
    @Name ("hola")
}
code:
    moveee r0, 1

    jmp r4
    jmp 0x100000

    adds r15b, r13b
    adds r15w, r13w
    addu r15d, r13d
    addu r15, r13

    subu r15b, r13b
    subu r15w, r13w
    subs r15d, r13d
    subs r15, r13

    muls r15b, r13b
    muls r15w, r13w
    mulu r15d, r13d
    mulu r15, r13

    divs r15b, r13b
    divs r15w, r13w
    divu r15d, r13d
    divu r15, r13

    cmpu r15b, r13b
    cmpu r15w, r13w
    cmps r15d, r13d
    cmps r15, r13

end_code:

data:
    msg db "Hola mundo"
    msg1 dq 0x123456789abcdef
end_data: